# Copy this file to .env and fill in your values

# Database — Cloud SQL (via Cloud SQL Python Connector) or local postgres/sqlite
DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Google Cloud project
PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
REGION=us-central1
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI Memory Bank — find/create via Vertex AI Agent Builder
AGENT_ENGINE_ID=your-agent-engine-id
MEMORY_BANK_ENGINE_NAME=fashionmind-demo

# Use Vertex AI backend (required for Memory Bank and gemini-live models)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Set to true to enable cross-session memory via Vertex AI Memory Bank
USE_MEMORY_BANK=true

# Live model — gemini-live-2.5-flash-native-audio recommended
DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio
